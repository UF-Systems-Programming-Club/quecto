%language=ANSI-C
%delimiters=","
%includes
%define lookup-function-name lookup_keyword
%struct-type
%{
#include "tokenizer.h"
%}
struct keyword;
%%
==,     TOKEN_EQUALS_EQUALS
=>,     TOKEN_ARROW
<=,     TOKEN_LESS_EQUALS
>=,     TOKEN_GREATER_EQUALS
return, TOKEN_RETURN
if,     TOKEN_IF
elif,   TOKEN_ELIF
else,   TOKEN_ELSE
while,  TOKEN_WHILE
proc,   TOKEN_PROC
extern, TOKEN_EXTERN
u32,    TOKEN_U32
i32,    TOKEN_I32
i8,     TOKEN_I8
u8,     TOKEN_U8
